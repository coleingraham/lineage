{
  "name": "@lineage/adapter-sqlite",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@lineage/core": "workspace:*",
    "better-sqlite3": "^12.8.0",
    "wa-sqlite": "^1.0.0"
  },
  "devDependencies": {
    "@lineage/eslint-config": "workspace:*",
    "@types/better-sqlite3": "^7.6.13",
    "eslint": "^10.1.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
