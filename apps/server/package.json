{
  "name": "@lineage/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "start": "tsx src/serve.ts",
    "dev": "tsx --watch src/serve.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.3",
    "@hono/zod-validator": "^0.7.6",
    "@lineage/adapter-ollama": "workspace:*",
    "@lineage/adapter-sqlite": "workspace:*",
    "@lineage/core": "workspace:*",
    "@lineage/sdk": "workspace:*",
    "better-sqlite3": "^12.8.0",
    "hono": "^4.12.10",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@lineage/eslint-config": "workspace:*",
    "@types/better-sqlite3": "^7.6.13",
    "eslint": "^10.1.0",
    "tsx": "^4.19.4",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
